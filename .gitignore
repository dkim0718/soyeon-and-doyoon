# =========================================================
# Assembled deploy copies (produced by scripts/assemble.mjs)
# ---------------------------------------------------------
# shared/ at the repo root is the single source of truth and
# stays tracked. These per-site copies are build output.
# =========================================================
/invite/shared/
/kr/shared/
/en/shared/
/admin/shared/
/admin/invite/
/admin/en/
/admin/kr/
/dist-root/

# Local-only Supabase keys you don't want committed.
shared/supabase-config.local.js

# Real private values (phones, bank account, passcode) kept out of the
# public repo. The committed invite/config.js carries placeholders;
# restore the real values from here at launch.
invite/config.private.js

